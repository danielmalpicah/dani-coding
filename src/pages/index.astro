---
import Layout from '../layouts/Layout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import SlashDivider from '../components/SlashDivider.astro';
import WhatsAppCta from '../components/WhatsAppCta.astro';
import {
  DIFFERENTIATORS,
  GALLERY,
  INDEX_ITEMS,
  NAV_ITEMS,
  PRICING_BMW,
  PRICING_VAG,
  PROCESS_PARTICULARES,
  PROCESS_REMOTO,
  PROCESS_TALLERES,
  REMOTE_LIMITS,
  REMOTE_REQUIREMENTS,
  REMOTE_SERVICES,
  SERVICES,
  STATS,
  TRUST_BADGES,
  waUrl,
} from '../lib/site';

const BMW_T1 = PRICING_BMW.filter((i) => i.tier === 1);
const BMW_DX = PRICING_BMW.filter((i) => i.tier === null);
const BMW_T2 = PRICING_BMW.filter((i) => i.tier === 2);
const VAG_T1 = PRICING_VAG.filter((i) => i.tier === 1);
const VAG_DX = PRICING_VAG.filter((i) => i.tier === null);
const VAG_T2 = PRICING_VAG.filter((i) => i.tier === 2);
import '../styles/global.css';
---

<Layout>
  <!-- OVERLAY MENÚ -->
  <div
    id="nav-overlay"
    class="fixed inset-0 z-40 flex flex-col justify-between px-6 py-8 bg-surface"
    aria-hidden="true"
  >
    <div class="flex items-center justify-between">
      <span class="font-display font-bold text-lg tracking-tight">
        Dani<span class="text-brand">Coding</span>
      </span>
      <button id="menu-close" class="label-editorial flex items-center gap-2 text-white" aria-label="Cerrar menú">
        <span class="text-xl leading-none">×</span>
        CERRAR
      </button>
    </div>

    <nav class="flex flex-col gap-1 mt-8 overflow-y-auto">
      {
        NAV_ITEMS.map((item) => (
          <a
            href={item.href}
            class:list={['flex items-baseline gap-5 py-3 group border-b border-border', item.sub && 'pl-8']}
          >
            <span class="code-tag shrink-0 min-w-18">
              {item.sub ? '└ ' : ''}
              {item.code}
            </span>
            <span
              class:list={[
                'font-mono font-bold text-white transition-colors duration-150 group-hover:text-brand',
                item.sub ? 'text-base' : 'text-2xl',
              ]}
            >
              {item.label}
            </span>
          </a>
        ))
      }
    </nav>

    <div class="pt-6">
      <WhatsAppCta class="inline-flex items-center gap-3 font-semibold text-sm px-6 py-3 bg-brand text-black transition-opacity hover:opacity-80">
        Cotizar por WhatsApp
      </WhatsAppCta>
    </div>
  </div>

  <!-- ÍNDICE LATERAL (desktop) -->
  <aside class="fixed right-6 top-1/2 z-30 -translate-y-1/2 flex-col gap-4 hidden lg:flex" aria-label="Navegación de secciones">
    {
      INDEX_ITEMS.map((item) => (
        <a href={`#${item.section}`} data-section={item.section} class="index-item flex items-center gap-3 group" aria-label={item.label}>
          <span class="index-label label-editorial text-right transition-opacity duration-200 opacity-0 group-hover:opacity-100 whitespace-nowrap text-muted-light">
            {item.code}
          </span>
          <span class="index-dot block w-px"></span>
        </a>
      ))
    }
  </aside>

  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-5">
    <span class="font-display font-bold text-lg tracking-tight">
      Dani<span class="text-brand">Coding</span>
    </span>
    <div class="flex items-center gap-4">
      <WhatsAppCta
        class="label-editorial text-white! border border-border-light px-4 py-2 hover:border-white/60 transition-colors duration-200 hidden sm:inline-flex items-center gap-2"
        iconSize={12}
      >
        Cotizar
      </WhatsAppCta>
      <button
        id="menu-open"
        class="label-editorial flex items-center gap-2 text-white border border-border-light px-4 py-2 transition-colors duration-200 hover:border-white/60"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="nav-overlay"
      >
        <span class="hidden sm:inline">MENÚ</span>
        <span class="text-base leading-none">≡</span>
      </button>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section id="hero" class="min-h-screen flex flex-col justify-end px-6 pb-24 pt-32 relative overflow-hidden bg-surface">
      <span class="hero-watermark absolute right-6 top-1/2 -translate-y-1/2 font-display font-bold select-none pointer-events-none hidden lg:block" aria-hidden="true">
        DC
      </span>

      <div class="max-w-5xl mx-auto w-full relative z-10">
        <div class="flex items-center gap-4 mb-10">
          <span class="label-editorial">BMW · Mini · VAG</span>
          <span class="text-border-light">/</span>
          <span class="label-editorial">Remoto en todo México</span>
        </div>

        <h1 class="display-hero font-display font-bold leading-none tracking-tighter mb-10">
          Funciones ocultas<br />
          <span class="text-brand">&amp; codificación</span><br />
          en todo México.
        </h1>

        <div class="flex flex-col sm:flex-row gap-5 items-start sm:items-center">
          <WhatsAppCta class="inline-flex items-center gap-3 font-semibold text-sm px-6 py-3 bg-brand text-black transition-opacity duration-200 hover:opacity-80">
            Cotizar por WhatsApp
          </WhatsAppCta>
          <span class="label-editorial">Respuesta en menos de 1 hora</span>
        </div>

        <!-- Stats -->
        <div class="flex flex-wrap gap-px mt-16 w-full border-t border-border">
          {
            STATS.map(([num, label], i) => (
              <div class="fade-up flex flex-col gap-1 pt-6 pr-10" data-delay={String(i + 1)}>
                <span class="font-display font-bold text-brand text-4xl leading-none">{num}</span>
                <span class="label-editorial">{label}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <SlashDivider direction="asc" class="bg-surface" />

    <!-- SERVICIOS -->
    <section id="servicios" class="px-6 py-24 bg-surface">
      <div class="max-w-5xl mx-auto">
        <SectionLabel label="Servicios" class="fade-up mb-14" />

        <div class="grid md:grid-cols-2 gap-px bg-border">
          {
            SERVICES.map((s, i) => (
              <article class="fade-up p-10 flex flex-col gap-6 relative bg-surface" data-delay={String(i + 1)}>
                <div class="corner-mark corner-mark-tl" />
                <div class="corner-mark corner-mark-br" />

                <div class="flex items-start justify-between">
                  <span class="code-tag">{s.code}</span>
                  <span class="label-editorial px-3 py-1 border border-border-light">{s.software}</span>
                </div>

                <div>
                  <h2 class="font-display font-bold text-3xl mb-1">{s.brand}</h2>
                  <p class="label-editorial text-muted-light">{s.models}</p>
                </div>

                <p class="text-sm leading-relaxed text-muted-light">{s.description}</p>

                <div class="flex flex-wrap gap-2 mt-auto pt-5 border-t border-border">
                  {s.tags.map((tag) => (
                    <span class="label-editorial px-3 py-1 bg-surface-2 text-muted-light">+ {tag}</span>
                  ))}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- PRECIOS -->
    <section id="precios" class="px-6 py-24 bg-surface-1">
      <div class="max-w-5xl mx-auto">
        <SectionLabel label="Precios" class="fade-up mb-4" />
        <p class="fade-up label-editorial text-muted-light mb-14 max-w-2xl" data-delay="1">
          Precios en MXN. Remoto aplica en todo México al mismo costo o −10% sin traslado.
          Domicilio CDMX/metro: +$300–600 según zona.
        </p>

        <div class="grid md:grid-cols-2 gap-px bg-border">
          <!-- BMW -->
          <div class="fade-up bg-surface-1" data-delay="1">
            <div class="flex items-center gap-4 px-8 py-6 border-b border-border">
              <span class="code-tag">BMW·001</span>
              <span class="font-display font-bold text-xl">BMW / Mini</span>
            </div>

            <div class="px-8 py-3 bg-surface-2 border-b border-border">
              <span class="label-editorial text-muted-light">Tier 1 · Coding &amp; funciones ocultas</span>
            </div>
            {
              BMW_T1.map((item) => (
                <div class="flex items-start justify-between gap-4 px-6 py-4 border-b border-border">
                  <span class="text-sm text-muted-light">{item.service}</span>
                  <div class="flex flex-col items-end gap-1 shrink-0">
                    <span class="text-sm font-mono text-brand whitespace-nowrap">{item.range}</span>
                    <a
                      href={waUrl(item.wa)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="label-editorial border border-border-light px-2.5 py-1 hover:border-white/60 hover:text-white transition-colors duration-150"
                    >
                      Agendar →
                    </a>
                  </div>
                </div>
              ))
            }

            <div class="px-8 py-3 bg-surface-2 border-b border-border">
              <span class="label-editorial text-muted-light">Diagnóstico</span>
            </div>
            {
              BMW_DX.map((item) => (
                <div class="flex items-start justify-between gap-4 px-6 py-4 border-b border-border">
                  <span class="text-sm text-muted-light">{item.service}</span>
                  <div class="flex flex-col items-end gap-1 shrink-0">
                    <span class="text-sm font-mono text-brand whitespace-nowrap">{item.range}</span>
                    <a
                      href={waUrl(item.wa)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="label-editorial border border-border-light px-2.5 py-1 hover:border-white/60 hover:text-white transition-colors duration-150"
                    >
                      Agendar →
                    </a>
                  </div>
                </div>
              ))
            }

            <div class="px-8 py-3 bg-surface-2 border-b border-border">
              <span class="label-editorial text-muted-light">Tier 2 · Activaciones con licencia</span>
            </div>
            {
              BMW_T2.map((item) => (
                <div class="flex items-start justify-between gap-4 px-6 py-4 border-b border-border last:border-b-0">
                  <span class="text-sm text-muted-light">{item.service}</span>
                  <div class="flex flex-col items-end gap-1 shrink-0">
                    <span class="text-sm font-mono text-brand whitespace-nowrap">{item.range}</span>
                    <a
                      href={waUrl(item.wa)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="label-editorial border border-border-light px-2.5 py-1 hover:border-white/60 hover:text-white transition-colors duration-150"
                    >
                      Agendar →
                    </a>
                  </div>
                </div>
              ))
            }
          </div>

          <!-- VAG -->
          <div class="fade-up bg-surface-1" data-delay="2">
            <div class="flex items-center gap-4 px-8 py-6 border-b border-border">
              <span class="code-tag">VAG·001</span>
              <span class="font-display font-bold text-xl">VAG · VW / Audi / Seat / Skoda</span>
            </div>

            <div class="px-8 py-3 bg-surface-2 border-b border-border">
              <span class="label-editorial text-muted-light">Tier 1 · Coding &amp; funciones ocultas</span>
            </div>
            {
              VAG_T1.map((item) => (
                <div class="flex items-start justify-between gap-4 px-6 py-4 border-b border-border">
                  <span class="text-sm text-muted-light">{item.service}</span>
                  <div class="flex flex-col items-end gap-1 shrink-0">
                    <span class="text-sm font-mono text-brand whitespace-nowrap">{item.range}</span>
                    <a
                      href={waUrl(item.wa)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="label-editorial border border-border-light px-2.5 py-1 hover:border-white/60 hover:text-white transition-colors duration-150"
                    >
                      Agendar →
                    </a>
                  </div>
                </div>
              ))
            }

            <div class="px-8 py-3 bg-surface-2 border-b border-border">
              <span class="label-editorial text-muted-light">Diagnóstico</span>
            </div>
            {
              VAG_DX.map((item) => (
                <div class="flex items-start justify-between gap-4 px-6 py-4 border-b border-border">
                  <span class="text-sm text-muted-light">{item.service}</span>
                  <div class="flex flex-col items-end gap-1 shrink-0">
                    <span class="text-sm font-mono text-brand whitespace-nowrap">{item.range}</span>
                    <a
                      href={waUrl(item.wa)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="label-editorial border border-border-light px-2.5 py-1 hover:border-white/60 hover:text-white transition-colors duration-150"
                    >
                      Agendar →
                    </a>
                  </div>
                </div>
              ))
            }

            <div class="px-8 py-3 bg-surface-2 border-b border-border">
              <span class="label-editorial text-muted-light">Tier 2 · Activaciones con licencia</span>
            </div>
            {
              VAG_T2.map((item) => (
                <div class="flex items-start justify-between gap-4 px-6 py-4 border-b border-border last:border-b-0">
                  <span class="text-sm text-muted-light">{item.service}</span>
                  <div class="flex flex-col items-end gap-1 shrink-0">
                    <span class="text-sm font-mono text-brand whitespace-nowrap">{item.range}</span>
                    <a
                      href={waUrl(item.wa)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="label-editorial border border-border-light px-2.5 py-1 hover:border-white/60 hover:text-white transition-colors duration-150"
                    >
                      Agendar →
                    </a>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <p class="fade-up label-editorial text-muted mt-6" data-delay="1">
          * Precios orientativos en MXN. Confirmar al agendar según modelo, año y especificaciones del vehículo.
        </p>
      </div>
    </section>

    <!-- GALERÍA -->
    <section id="galeria" class="px-6 py-24 bg-surface-1">
      <div class="max-w-5xl mx-auto">
        <SectionLabel label="Galería" class="fade-up mb-14" />

        <div class="grid md:grid-cols-3 gap-px bg-border">
          {
            GALLERY.map((img, i) => (
              <figure class="fade-up relative overflow-hidden group bg-surface-2 aspect-3/4 m-0" data-delay={String(i + 1)}>
                <img
                  src={img.src}
                  alt={img.caption}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
                <figcaption class="caption-gradient absolute bottom-0 left-0 right-0 px-4 py-3 flex items-center justify-between">
                  <span class="label-editorial text-white!">{img.caption}</span>
                  <span class="code-tag">0{i + 1}</span>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </section>

    <SlashDivider direction="desc" class="bg-surface" />

    <!-- PROCESO -->
    <section id="proceso" class="px-6 py-24 bg-surface">
      <div class="max-w-5xl mx-auto">
        <SectionLabel label="Cómo funciona" class="fade-up mb-14" />

        <div class="grid md:grid-cols-3 gap-px bg-border">
          <article class="fade-up p-10 relative bg-surface" data-delay="1">
            <div class="corner-mark corner-mark-tl"></div>
            <div class="flex items-center gap-3 mb-6">
              <span class="code-tag">003-A</span>
              <span class="label-editorial px-3 py-1 bg-surface-2 text-brand!">+ Particulares</span>
            </div>
            <h3 class="font-display font-bold text-2xl mb-3">Trae tu auto<br />al taller</h3>
            <p class="text-sm leading-relaxed mb-6 text-muted-light">
              Atendemos clientes particulares directamente en nuestras instalaciones en Texcoco, Estado de México. Agenda tu cita y llega con tu vehículo.
            </p>
            <ol class="space-y-3 list-none m-0 p-0">
              {
                PROCESS_PARTICULARES.map((step, i) => (
                  <li class="flex items-center gap-4">
                    <span class="code-tag shrink-0">0{i + 1}</span>
                    <span class="text-sm text-muted-light">{step}</span>
                  </li>
                ))
              }
            </ol>
          </article>

          <article class="fade-up p-10 relative bg-surface" data-delay="2">
            <div class="corner-mark corner-mark-tl"></div>
            <div class="flex items-center gap-3 mb-6">
              <span class="code-tag">003-B</span>
              <span class="label-editorial px-3 py-1 bg-surface-2 text-brand!">+ Talleres</span>
            </div>
            <h3 class="font-display font-bold text-2xl mb-3">Vamos<br />a tu taller</h3>
            <p class="text-sm leading-relaxed mb-6 text-muted-light">
              Si eres un taller establecido que no cuenta con las herramientas de nivel concesionario, llevamos el equipo a tus instalaciones en CDMX y Área Metropolitana.
            </p>
            <ol class="space-y-3 list-none m-0 p-0">
              {
                PROCESS_TALLERES.map((step, i) => (
                  <li class="flex items-center gap-4">
                    <span class="code-tag shrink-0">0{i + 1}</span>
                    <span class="text-sm text-muted-light">{step}</span>
                  </li>
                ))
              }
            </ol>
          </article>

          <article class="fade-up p-10 relative bg-surface" data-delay="3">
            <div class="corner-mark corner-mark-tl"></div>
            <div class="flex items-center gap-3 mb-6">
              <span class="code-tag">003-C</span>
              <span class="label-editorial px-3 py-1 bg-surface-2 text-brand!">+ Remoto</span>
            </div>
            <h3 class="font-display font-bold text-2xl mb-3">Nos conectamos<br />a tu laptop</h3>
            <p class="text-sm leading-relaxed mb-6 text-muted-light">
              Con un cable ENET y acceso remoto por AnyDesk/TeamViewer, hacemos la codificación sin que el vehículo salga de donde está.
            </p>
            <ol class="space-y-3 list-none m-0 p-0">
              {
                PROCESS_REMOTO.map(([title], i) => (
                  <li class="flex items-center gap-4">
                    <span class="code-tag shrink-0">0{i + 1}</span>
                    <span class="text-sm text-muted-light">{title}</span>
                  </li>
                ))
              }
            </ol>
          </article>
        </div>

        <div class="grid md:grid-cols-2 gap-px bg-border mt-px">
          <div class="fade-up p-10 relative bg-surface">
            <div class="corner-mark corner-mark-tl" />
            <p class="code-tag mb-6">QUÉ HACEMOS REMOTAMENTE</p>
            <ul class="space-y-3 list-none m-0 p-0">
              {
                REMOTE_SERVICES.map((s) => (
                  <li class="flex items-start gap-3">
                    <span class="text-brand font-mono text-xs shrink-0 mt-0.5">+</span>
                    <span class="text-sm text-muted-light">{s}</span>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="fade-up p-10 relative bg-surface" data-delay="2">
            <div class="corner-mark corner-mark-tl" />
            <p class="code-tag mb-6">REQUISITOS</p>
            <ul class="space-y-4 list-none m-0 p-0 mb-8">
              {
                REMOTE_REQUIREMENTS.map((r) => (
                  <li class="flex items-start gap-3">
                    <span class="text-brand font-mono text-xs shrink-0 mt-0.5">✓</span>
                    <span class="text-sm text-muted-light">{r}</span>
                  </li>
                ))
              }
            </ul>
            <div class="pt-6 border-t border-border">
              <p class="code-tag mb-3">REQUIERE VISITA AL TALLER</p>
              <ul class="space-y-2 list-none m-0 p-0">
                {
                  REMOTE_LIMITS.map((l) => (
                    <li class="flex items-start gap-3">
                      <span class="label-editorial text-muted shrink-0">—</span>
                      <span class="label-editorial text-muted">{l}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <div class="fade-up mt-8 flex flex-col sm:flex-row gap-4 items-start sm:items-center">
          <WhatsAppCta
            class="inline-flex items-center gap-3 font-semibold text-sm px-6 py-3 bg-brand text-black transition-opacity duration-200 hover:opacity-80"
          >
            Consultar compatibilidad remota
          </WhatsAppCta>
          <span class="label-editorial text-muted-light">
            Envíanos el VIN corto + versión de firmware del head unit
          </span>
        </div>
      </div>
    </section>

    <SlashDivider direction="asc" class="bg-surface-1" />

    <!-- POR QUÉ -->
    <section id="diferenciadores" class="px-6 py-24 bg-surface-1">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-16 items-center mb-12">
        <div>
          <SectionLabel label="Por qué Dani Coding" class="fade-up mb-8" />
          <h2 class="display-section font-display font-bold leading-tight tracking-tight mb-6">
            Software de<br />concesionario,<br />
            <span class="text-brand">precio de taller.</span>
          </h2>
          <p class="text-sm leading-relaxed text-muted-light">
            Los concesionarios cobran horas de mano de obra por servicios que con el software correcto toman minutos. Usamos exactamente las mismas herramientas que la red oficial, sin intermediarios y sin costos inflados.
          </p>
        </div>

        <div class="border border-border">
          {
            DIFFERENTIATORS.map(([num, title, desc]) => (
              <div class="px-6 py-5 border-b border-border last:border-b-0">
                <div class="flex items-start gap-4">
                  <span class="code-tag shrink-0 mt-0.5">{num}</span>
                  <div>
                    <p class="text-sm font-medium mb-1">{title}</p>
                    <p class="label-editorial">{desc}</p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
        </div>

        <div class="grid md:grid-cols-3 gap-px bg-border">
          {
            TRUST_BADGES.map(([title, sub]) => (
              <div class="fade-up px-6 py-5 bg-surface-1">
                <p class="text-sm font-medium mb-1">{title}</p>
                <p class="label-editorial">{sub}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- COBERTURA -->
    <section id="cobertura" class="px-6 py-24 bg-surface">
      <div class="max-w-5xl mx-auto">
        <SectionLabel label="Cobertura & horario" class="fade-up mb-14" />

        <div class="grid md:grid-cols-3 gap-px bg-border">
          <div class="fade-up px-8 py-10 relative bg-surface" data-delay="1">
            <div class="corner-mark corner-mark-tl"></div>
            <p class="code-tag mb-2">005-A · UBICACIÓN</p>
            <p class="font-display font-bold text-xl mb-3">Taller</p>
            <p class="text-sm leading-relaxed text-muted-light">
              Lomas de Cristo<br />
              Texcoco, Estado de México
            </p>
          </div>
          <div class="fade-up px-8 py-10 relative bg-surface" data-delay="2">
            <div class="corner-mark corner-mark-tl"></div>
            <p class="code-tag mb-2">005-B · COBERTURA</p>
