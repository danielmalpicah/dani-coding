---
// Divisor de slashes diagonales estilo editorial.
// `asc`: las líneas suben de izquierda a derecha; `desc`: bajan.

interface Props {
  direction?: 'asc' | 'desc';
  class?: string;
}

const { direction = 'asc', class: className = '' } = Astro.props;

const X_STARTS = [0, 120, 240, 560, 680, 900, 1020, 1140];
const SLASH_LENGTH = 360;
---

<div class={`w-full overflow-hidden h-12 -mt-px ${className}`} aria-hidden="true">
  <svg viewBox="0 0 1440 48" preserveAspectRatio="none" width="100%" height="48">
    {
      X_STARTS.map((x) => (
        <line
          x1={x}
          y1={direction === 'asc' ? 48 : 0}
          x2={x + SLASH_LENGTH}
          y2={direction === 'asc' ? 0 : 48}
          stroke="var(--color-border)"
          stroke-width="1"
        />
      ))
    }
  </svg>
</div>
