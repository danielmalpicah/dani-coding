---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dani Coding — Programación Automotriz Nivel Concesionario | Texcoco, EDOMEX',
  description = 'Programación automotriz nivel concesionario en Texcoco, Estado de México. ODIS para Volkswagen, Audi, Seat y Skoda. ISTA + E-SYS para BMW. Servicio a domicilio en CDMX y Área Metropolitana.',
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  "name": "Dani Coding",
  "description": "Programación automotriz nivel concesionario. ODIS para Grupo VAG, ISTA y E-SYS para BMW.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lomas de Cristo",
    "addressLocality": "Texcoco",
    "addressRegion": "Estado de México",
    "addressCountry": "MX"
  },
  "areaServed": ["Texcoco", "Estado de México", "Ciudad de México", "Zona Metropolitana del Valle de México"],
  "openingHours": "Mo-Su 00:00-23:59",
  "telephone": "+525542868902",
  "priceRange": "$$",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de programación automotriz",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Programación Grupo VAG con ODIS Engineering" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Programación BMW con ISTA y E-SYS" } }
    ]
  }
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="programación automotriz Texcoco, programación ECU CDMX, ODIS Volkswagen Audi México, ISTA BMW México, codificación BMW CDMX, programación VAG Estado de México, diagnóstico automotriz nivel concesionario" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="robots" content="index, follow" />
    <meta name="geo.region" content="MX-MEX" />
    <meta name="geo.placename" content="Texcoco, Estado de México" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
