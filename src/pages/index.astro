---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const WHATSAPP_NUMBER = '525542868902'; // reemplazar con número real
const WHATSAPP_MSG = encodeURIComponent('Hola, me interesa una cotización para programación automotriz.');
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MSG}`;

const services = [
  {
    id: '01',
    brand: 'Grupo VAG',
    models: 'Volkswagen · Audi · Seat · Skoda',
    software: 'ODIS Engineering',
    description: 'Diagnóstico, codificación, adaptaciones y programación de módulos con el mismo software que usa la red oficial de concesionarios VAG.',
    tags: ['Codificación', 'Adaptaciones', 'Flash ECU', 'Activación de funciones'],
  },
  {
    id: '02',
    brand: 'BMW',
    models: 'BMW · Mini',
    software: 'ISTA-D · E-SYS',
    description: 'Diagnóstico integral con ISTA y programación/codificación profunda de módulos con E-SYS. Funciones ocultas, retrofits y actualizaciones de software.',
    tags: ['E-SYS Coding', 'ISTA Diagnóstico', 'Retrofits', 'Hidden Features'],
  },
];
---

<Layout>
  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-5 mix-blend-difference">
    <span class="font-display font-bold text-lg tracking-tight text-white">
      Dani<span style="color: var(--color-brand)">Coding</span>
    </span>
    <a
      href={WHATSAPP_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm font-medium text-white border border-white/20 rounded-full px-4 py-2 hover:border-white/60 transition-colors duration-200"
    >
      Contactar
    </a>
  </header>

  <main>
    <!-- HERO -->
    <section class="min-h-screen flex flex-col justify-end px-6 pb-20 pt-32" style="background-color: var(--color-surface);">
      <div class="max-w-5xl mx-auto w-full">
        <p class="text-xs font-medium tracking-widest uppercase mb-6" style="color: var(--color-muted);">
          Programación automotriz nivel concesionario
        </p>
        <h1 class="font-display font-bold leading-none tracking-tighter mb-8" style="font-size: clamp(3.5rem, 10vw, 8rem);">
          Diagnóstico<br />
          <span style="color: var(--color-brand);">y codificación</span><br />
          de élite.
        </h1>
        <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 font-semibold text-sm px-6 py-3 rounded-full transition-opacity duration-200 hover:opacity-80"
            style="background-color: var(--color-brand); color: #000;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Cotizar por WhatsApp
          </a>
          <span class="text-sm" style="color: var(--color-muted);">Respuesta en menos de 1 hora</span>
        </div>
      </div>
    </section>

    <!-- DIVISOR -->
    <div class="h-px w-full" style="background-color: var(--color-border);"></div>

    <!-- SERVICIOS -->
    <section id="servicios" class="px-6 py-24" style="background-color: var(--color-surface);">
      <div class="max-w-5xl mx-auto">
        <p class="text-xs font-medium tracking-widest uppercase mb-12" style="color: var(--color-muted);">
          — Servicios
        </p>
        <div class="grid md:grid-cols-2 gap-px" style="background-color: var(--color-border);">
          {services.map((s) => (
            <div class="p-10 flex flex-col gap-6" style="background-color: var(--color-surface);">
              <div class="flex items-start justify-between">
                <span class="text-xs font-mono" style="color: var(--color-muted);">{s.id}</span>
                <span class="text-xs font-medium tracking-widest uppercase px-3 py-1 rounded-full border" style="border-color: var(--color-border); color: var(--color-muted);">
                  {s.software}
                </span>
              </div>
              <div>
                <h2 class="font-display font-bold text-3xl mb-1">{s.brand}</h2>
                <p class="text-sm" style="color: var(--color-muted);">{s.models}</p>
              </div>
              <p class="text-sm leading-relaxed" style="color: #aaaaaa;">{s.description}</p>
              <div class="flex flex-wrap gap-2 mt-auto pt-4" style="border-top: 1px solid var(--color-border);">
                {s.tags.map((tag) => (
                  <span class="text-xs px-3 py-1 rounded-full" style="background-color: var(--color-surface-2); color: var(--color-muted);">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- DIVISOR -->
    <div class="h-px w-full" style="background-color: var(--color-border);"></div>

    <!-- POR QUÉ -->
    <section class="px-6 py-24" style="background-color: var(--color-surface-1);">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-medium tracking-widest uppercase mb-6" style="color: var(--color-muted);">
            — Por qué Dani Coding
          </p>
          <h2 class="font-display font-bold text-4xl md:text-5xl leading-tight tracking-tight mb-6">
            Software de concesionario,<br />
            <span style="color: var(--color-brand);">precio de taller.</span>
          </h2>
          <p class="text-sm leading-relaxed" style="color: #aaaaaa;">
            Los concesionarios cobran horas de mano de obra por servicios que con el software correcto toman minutos. Usamos exactamente las mismas herramientas que la red oficial, sin intermediarios y sin costos inflados.
          </p>
        </div>
        <div class="flex flex-col gap-px" style="border: 1px solid var(--color-border);">
          {[
            ['Software oficial de fábrica', 'ODIS, ISTA-D y E-SYS — no herramientas genéricas'],
            ['Sin viaje al concesionario', 'Diagnóstico preciso desde tu taller o domicilio'],
            ['Activación de funciones', 'Features bloqueados de fábrica habilitados vía software'],
            ['Más marcas próximamente', 'Expansión continua a otras marcas premium'],
          ].map(([title, desc]) => (
            <div class="px-6 py-5" style="background-color: var(--color-surface); border-bottom: 1px solid var(--color-border);">
              <p class="font-medium text-sm mb-1">{title}</p>
              <p class="text-xs" style="color: var(--color-muted);">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- DIVISOR -->
    <div class="h-px w-full" style="background-color: var(--color-border);"></div>

    <!-- CONTACTO / CTA -->
    <section id="contacto" class="px-6 py-32 text-center" style="background-color: var(--color-surface);">
      <div class="max-w-2xl mx-auto">
        <p class="text-xs font-medium tracking-widest uppercase mb-8" style="color: var(--color-muted);">
          — Contacto
        </p>
        <h2 class="font-display font-bold leading-none tracking-tighter mb-8" style="font-size: clamp(2.5rem, 7vw, 5rem);">
          ¿Tu auto necesita<br />
          <span style="color: var(--color-brand);">programación?</span>
        </h2>
        <p class="text-sm mb-10" style="color: var(--color-muted);">
          Escríbenos directamente. Respondemos en menos de 1 hora.
        </p>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 font-semibold text-base px-8 py-4 rounded-full transition-opacity duration-200 hover:opacity-80"
          style="background-color: var(--color-brand); color: #000;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Escribir por WhatsApp
        </a>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="px-6 py-8 flex items-center justify-between" style="border-top: 1px solid var(--color-border); color: var(--color-muted);">
    <span class="font-display font-bold text-sm">
      Dani<span style="color: var(--color-brand);">Coding</span>
    </span>
    <span class="text-xs">Programación automotriz nivel concesionario</span>
  </footer>

  <!-- WhatsApp flotante -->
  <a
    href={WHATSAPP_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 rounded-full shadow-lg transition-transform duration-200 hover:scale-110"
    style="background-color: #25d366;"
    aria-label="Contactar por WhatsApp"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="white">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
</Layout>
